# listen
PORT=43111
HOST=0.0.0.0

# ===== 自定义 API 包装转发（主路径） =====
# 上游地址（不带尾斜杠）
CUSTOM_UPSTREAM_BASE_URL=https://your-custom-api.example.com
# 上游聊天路径
CUSTOM_UPSTREAM_CHAT_PATH=/v1/chat/completions
# 如需固定上游授权，可填：
CUSTOM_UPSTREAM_API_KEY=
# 固定额外请求头（JSON 字符串）
CUSTOM_UPSTREAM_EXTRA_HEADERS={}
# 请求超时（毫秒）
CUSTOM_TIMEOUT_MS=180000

# ===== Codex 授权转发（同一路径按 model 分流） =====
# 当 model 命中 CODEX_MODEL_MATCH 时，转发到这里。
CODEX_MODEL_MATCH=openai-codex/,codex
CODEX_UPSTREAM_BASE_URL=https://api.openai.com
CODEX_UPSTREAM_CHAT_PATH=/v1/chat/completions
# true: 必须由客户端携带 Authorization: Bearer <codex-token>
# false: 若客户端没带，则使用 CODEX_FALLBACK_API_KEY
CODEX_REQUIRE_CLIENT_AUTH=true
CODEX_FALLBACK_API_KEY=
CODEX_TIMEOUT_MS=180000

# ===== Codex 独立 OAuth（可选，开启后优先使用） =====
# 开启后，命中 codex 模型时会使用 /oauth/start + /oauth/callback 获取并自动刷新 token
CODEX_OAUTH_ENABLED=false
CODEX_OAUTH_AUTHORIZE_URL=
CODEX_OAUTH_TOKEN_URL=
CODEX_OAUTH_CLIENT_ID=
CODEX_OAUTH_CLIENT_SECRET=
CODEX_OAUTH_SCOPE=
# 建议配置为公网可访问回调地址（先 HTTP 跑通再升级 HTTPS）
CODEX_OAUTH_REDIRECT_URI=http://127.0.0.1:43111/oauth/callback
CODEX_OAUTH_TOKEN_FILE=./codex-oauth-token.json

# ===== 安全 =====
# 如需给你的转发服务再加一道门：请求头 X-Forward-Token 必须等于这个值
FORWARD_SERVICE_TOKEN=

# ===== 路由 =====
# 统一入口（OpenAI 兼容）：
#   POST /v1/chat/completions
# 分流规则：
#   - model 命中 CODEX_MODEL_MATCH -> Codex 上游
#   - 其他 -> 自定义 API 上游
